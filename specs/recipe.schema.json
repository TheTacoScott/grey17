{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/TheTacoScott/grey17/docs/recipe.schema.json",
  "title": "grey17 Recipe",
  "description": "A grey17 fan-edit recipe file. Describes the source slots used in a Blender VSE edit, with fingerprint anchor points that allow viewers to match and conform their own copies of the source material.",
  "type": "object",
  "required": ["grey17_version", "recipe_version", "signed", "created_at", "metadata", "blender", "scene", "output", "sources"],
  "additionalProperties": false,

  "properties": {

    "grey17_version": {
      "description": "grey17 toolchain version that produced this file.",
      "type": ["string", "integer"]
    },

    "recipe_version": {
      "description": "Recipe format version. Currently '1.0'.",
      "type": ["string", "number"]
    },

    "signed": {
      "description": "True once sign-recipe has run and anchor data has been written.",
      "type": "boolean"
    },

    "created_at": {
      "description": "ISO 8601 UTC timestamp when the recipe was generated.",
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },

    "metadata": {
      "description": "Human-readable information about the edit.",
      "type": "object",
      "required": ["title", "author", "blend_file"],
      "additionalProperties": false,
      "properties": {
        "title":      { "type": "string" },
        "author":     { "type": "string" },
        "blend_file": { "type": "string", "description": "Filename (not path) of the .blend file." }
      }
    },

    "blender": {
      "description": "Blender version used to create the .blend file.",
      "type": "object",
      "required": ["version"],
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": "string",
          "description": "Version string, e.g. '2.91.0'."
        },
        "version_tuple": {
          "type": ["array", "null"],
          "items": { "type": "integer" },
          "minItems": 3,
          "maxItems": 3,
          "description": "[major, minor, patch]"
        }
      }
    },

    "scene": {
      "description": "Blender scene render settings as recorded by generate-recipe.",
      "type": "object",
      "required": ["fps", "fps_base", "effective_fps", "frame_start", "frame_end", "duration_seconds", "resolution_x", "resolution_y"],
      "additionalProperties": false,
      "properties": {
        "fps":              { "type": "number", "description": "Blender scene fps numerator." },
        "fps_base":         { "type": "number", "description": "Blender scene fps denominator." },
        "effective_fps":    { "type": "number", "description": "fps / fps_base, rounded." },
        "frame_start":      { "type": "integer" },
        "frame_end":        { "type": "integer" },
        "duration_seconds": { "type": "number" },
        "resolution_x":     { "type": "integer" },
        "resolution_y":     { "type": "integer" }
      }
    },

    "output": {
      "description": "Default render output settings for cook. All fields are overridable via grey17 cook flags.",
      "type": "object",
      "required": ["format", "video_codec", "audio_codec"],
      "additionalProperties": false,
      "properties": {
        "format":       { "type": "string", "enum": ["mkv", "mp4", "mov", "avi"], "description": "Container format." },
        "video_codec":  { "type": "string", "description": "ffmpeg video codec name, e.g. 'libx265', 'libx264'." },
        "crf":          { "type": ["integer", "null"], "minimum": 0, "maximum": 51 },
        "audio_codec":  { "type": "string", "description": "ffmpeg audio codec name, e.g. 'aac', 'mp3'." },
        "audio_bitrate":{ "type": ["string", "null"], "pattern": "^[0-9]+k$", "description": "Audio bitrate, e.g. '320k'." },
        "resolution_x": { "type": ["integer", "null"] },
        "resolution_y": { "type": ["integer", "null"] },
        "fps":          { "type": ["number", "null"] }
      }
    },

    "sources": {
      "description": "One entry per distinct source video file used in the VSE timeline.",
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Source" }
    }
  },

  "$defs": {

    "Source": {
      "type": "object",
      "required": ["id", "name", "description", "required", "expect_full_frame", "original", "strip_timecodes"],
      "additionalProperties": false,
      "properties": {

        "id": {
          "type": "string",
          "pattern": "^source_[0-9]+$",
          "description": "Stable slot identifier, e.g. 'source_0'."
        },

        "name": {
          "type": "string",
          "description": "Human-readable name the author gives this slot. Viewers read this to know what file to provide."
        },

        "description": {
          "type": "string",
          "description": "Extended description - release notes, edition info, etc."
        },

        "required": {
          "type": "boolean",
          "description": "Whether this slot must be matched for the conform to proceed."
        },

        "expect_full_frame": {
          "type": "boolean",
          "description": "True if the author's source has no black bars (pillarbox/letterbox). When true, grey17 match will run crop detection on viewer-supplied files and grey17 conform will remove detected bars."
        },

        "original": {
          "description": "Metadata about the author's source file. Populated by sign-recipe.",
          "type": "object",
          "required": ["filename", "filepath_on_author_machine"],
          "additionalProperties": false,
          "properties": {
            "filename":                  { "type": "string", "description": "Bare filename (no path)." },
            "filepath_on_author_machine":{ "type": "string", "description": "Absolute path on the author's machine at sign time." },
            "file_size_bytes":           { "type": ["integer", "null"] },
            "file_exists_at_sign_time":  { "type": "boolean" },
            "sha256":                    { "type": ["string", "null"], "pattern": "^[0-9a-f]{64}$", "description": "SHA-256 hex digest. Populated by sign-recipe." },
            "resolution_x":              { "type": ["integer", "null"] },
            "resolution_y":              { "type": ["integer", "null"] },
            "fps":                       { "type": ["number", "null"] },
            "duration_seconds":          { "type": ["number", "null"] },
            "duration_frames":           { "type": ["integer", "null"] },
            "video_codec":               { "type": ["string", "null"] },
            "audio_codec":               { "type": ["string", "null"] },
            "audio_channels":            { "type": ["integer", "null"] },
            "audio_sample_rate":         { "type": ["string", "integer", "null"] },
            "detected_crop": {
              "description": "Crop detected in the author's source. Non-null means the author's file itself has black bars. Viewers should not expect to have their files cropped when expect_full_frame is false.",
              "oneOf": [
                { "type": "null" },
                { "$ref": "#/$defs/CropRect" }
              ]
            }
          }
        },

        "strip_timecodes": {
          "description": "Timecodes of strip in/out points from the VSE timeline. Used by sign-recipe to place dense anchor sequences at cut points.",
          "type": "array",
          "items": {
            "type": "object",
            "required": ["timecode", "role", "strip"],
            "additionalProperties": false,
            "properties": {
              "timecode": { "type": "number", "minimum": 0 },
              "role":     { "type": "string", "enum": ["strip_in", "strip_out"] },
              "strip":    { "type": "string", "description": "Name of the VSE strip." }
            }
          }
        },

        "anchors": {
          "description": "Fingerprint anchor points. Populated by sign-recipe. Empty array before signing.",
          "type": "array",
          "items": { "$ref": "#/$defs/Anchor" }
        }
      }
    },

    "Anchor": {
      "description": "A single fingerprint sample point in the source video.",
      "type": "object",
      "required": ["timecode", "role", "video", "audio"],
      "additionalProperties": false,
      "properties": {

        "timecode": {
          "type": "number",
          "minimum": 0,
          "description": "Position in seconds within the source file."
        },

        "role": {
          "type": "string",
          "enum": ["interval", "strip_in", "strip_out"],
          "description": "interval: regular time-spaced sample. strip_in/strip_out: positioned at a VSE cut point."
        },

        "strip_refs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "VSE strip names associated with this anchor (present when role is strip_in or strip_out)."
        },

        "low_entropy": {
          "type": "boolean",
          "description": "True if the frame is solid black or white (mean pixel value < 5 or > 250). Down-weighted during matching."
        },

        "video": {
          "type": "object",
          "required": ["phash", "ahash"],
          "additionalProperties": false,
          "properties": {
            "phash": {
              "type": ["string", "null"],
              "pattern": "^[0-9a-f]{16}$",
              "description": "Perceptual hash (DCT-based) of a 32x32 grayscale frame sample. 16-char hex = 64-bit hash. Hamming distance < 10 is a match."
            },
            "ahash": {
              "type": ["string", "null"],
              "pattern": "^[0-9a-f]{16}$",
              "description": "Average hash of the same frame. Used as a secondary signal."
            }
          }
        },

        "audio": {
          "type": "object",
          "required": ["fingerprint"],
          "additionalProperties": false,
          "properties": {
            "fingerprint": {
              "type": ["string", "null"],
              "description": "Chromaprint audio fingerprint for a 1-second window at this timecode. Base64 URL-safe encoded. Bit error rate < 0.35 is a match."
            }
          }
        },

        "cut_sequence": {
          "description": "Dense native-fps frame hash sequence around a cut point. Only present for strip_in/strip_out anchors. Used for frame-precise alignment in Phase 4 of matching.",
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "required": ["window_start_tc", "fps", "phashes", "reliable"],
              "additionalProperties": false,
              "properties": {
                "window_start_tc": {
                  "type": "number",
                  "minimum": 0,
                  "description": "Timecode of the first frame in the sequence (cut_tc - 2.0s, clamped to 0)."
                },
                "fps": {
                  "type": "number",
                  "description": "Frame rate at which frames were extracted."
                },
                "phashes": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "pattern": "^[0-9a-f]{16}$"
                  },
                  "description": "pHash for each frame in the window, in order."
                },
                "reliable": {
                  "type": "boolean",
                  "description": "False if the majority of frames in the window are low-entropy (e.g. fade-to-black at a cut point). When false, this sequence is not used in Phase 4."
                }
              }
            }
          ]
        }
      }
    },

    "CropRect": {
      "description": "A crop rectangle in ffmpeg crop=W:H:X:Y format. W and H are the output dimensions; X and Y are the offset of the top-left corner in the input frame.",
      "type": "object",
      "required": ["w", "h", "x", "y"],
      "additionalProperties": false,
      "properties": {
        "w": { "type": "integer", "minimum": 1 },
        "h": { "type": "integer", "minimum": 1 },
        "x": { "type": "integer", "minimum": 0 },
        "y": { "type": "integer", "minimum": 0 }
      }
    }

  }
}
